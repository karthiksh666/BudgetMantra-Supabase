# ── Supabase ──────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret — Supabase Dashboard → Project Settings → API → JWT Secret
JWT_SECRET=your-supabase-jwt-secret
JWT_ALGORITHM=HS256

# ── AI ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google OAuth (optional) ───────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Firebase phone auth (optional) ───────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_JSON=

# ── App ───────────────────────────────────────────────────────
APP_URL=https://budget-mantra-nine.vercel.app
ADMIN_SECRET=your-admin-secret
CORS_ORIGINS=http://localhost:3000,https://budget-mantra-nine.vercel.app

# ── Email / SMTP (optional) ───────────────────────────────────
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
